# =====================================================================
# Konfigurasi Supabase — SALIN file ini menjadi .env.local lalu isi nilainya.
# Ambil nilai di: Supabase Dashboard > Project Settings > API
# JANGAN commit file .env.local ke git.
# =====================================================================

# URL project Supabase, mis. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon"/"publishable" key — aman dipakai di browser (dilindungi RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Opsional) URL publik stabil untuk QR code, mis. https://panduan.rutanbalikpapan.go.id
# Dipakai hanya untuk dokumentasi/redirect. Lihat README bagian "Catatan QR".
NEXT_PUBLIC_SITE_URL=
